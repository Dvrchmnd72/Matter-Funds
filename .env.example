# ---------------------------------------------------------------
# Matter Funds – environment variable template
# Copy this file to .env and fill in your real values.
# The .env file is listed in .gitignore – never commit it.
# ---------------------------------------------------------------

# Django secret key
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CHANGE_ME

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated list of allowed hostnames (no spaces)
DJANGO_ALLOWED_HOSTS=www.matterfunds.com.au,matterfunds.com.au

# ---------------------------------------------------------------
# PostgreSQL database settings
#
# PythonAnywhere note:
#   Your Postgres port is NOT the default 5432.
#   Check the "Databases" tab in your PythonAnywhere dashboard for
#   the actual port (e.g. 14321).
#   Host format: <username>-<number>.postgres.pythonanywhere-services.com
# ---------------------------------------------------------------
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
